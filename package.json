{
  "name": "sponsor-motor",
  "version": "1.2.5",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for LCV Ideas & Software sponsor payments via Mercado Pago Checkout Transparente Orders API.",
  "license": "AGPL-3.0-or-later",
  "author": "LCV Ideas & Software",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LCV-Ideas-Software/sponsor-motor.git"
  },
  "homepage": "https://www.lcv.dev/sponsor",
  "bugs": {
    "url": "https://github.com/LCV-Ideas-Software/sponsor-motor/issues"
  },
  "scripts": {
    "format": "biome format --write src && prettier --write \"**/index.html\" \"*.md\" \".github/**/*.yml\" \"*.json\"",
    "format:check": "biome check src && prettier --check \"**/index.html\" \"*.md\" \".github/**/*.yml\" \"*.json\"",
    "format:public": "prettier --write \"**/index.html\"",
    "format:public:check": "prettier --check \"**/index.html\"",
    "lint": "biome lint src",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "deploy": "wrangler deploy",
    "db:migrate:remote": "wrangler d1 migrations apply bigdata_db --remote"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "mercadopago": "3.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/workers-types": "^5.20260716.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "ws": "8.21.0",
    "uuid": "^11.0.0",
    "esbuild": "0.28.1"
  }
}
